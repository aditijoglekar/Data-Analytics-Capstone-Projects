-- QUERY 1: Total Revenue & Business Metrics
SELECT 
    COUNT(DISTINCT InvoiceNo) as total_orders,
    COUNT(DISTINCT CustomerID) as total_customers,
    COUNT(DISTINCT StockCode) as total_products,
    SUM(CAST(Quantity AS INT)) as total_items_sold,
    ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as total_revenue,
    ROUND(AVG(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as avg_order_value
FROM MyDatabase.dbo.online_retail
WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0;

--QUERY 2 Top 10 Products by Revenue
SELECT 
    TOP 10 StockCode, 
    Description, 
    COUNT(DISTINCT InvoiceNo) as num_orders, 
    SUM(CAST(Quantity AS INT)) as total_qty, 
    ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as total_revenue 
FROM MyDatabase.dbo.online_retail 
WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 GROUP BY StockCode, 
Description 
ORDER BY total_revenue DESC;

