    THEN 'Medium (50-200)' ELSE 'High (> 200)' END as order_value_segment, 
    COUNT(*) as num_line_items, 
    COUNT(DISTINCT InvoiceNo) as distinct_orders, 
    COUNT(DISTINCT CustomerID) as num_customers, 
    ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as segment_revenue 
    FROM MyDatabase.dbo.online_retail 
    WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 
    GROUP BY CASE WHEN CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT) < 50 
    THEN 'Low (< 50)' 
    WHEN CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT) < 200 
    THEN 'Medium (50-200)' ELSE 'High (> 200)' END 
    ORDER BY segment_revenue DESC;

