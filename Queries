--QUERY 7 Customer Lifetime Value (CLV) 
SELECT 
    TOP 30 CustomerID, 
    COUNT(DISTINCT InvoiceNo) as total_orders, 
    COUNT(DISTINCT StockCode) as distinct_products, 
    MIN(CAST(InvoiceDate AS DATETIME)) as first_purchase, 
    MAX(CAST(InvoiceDate AS DATETIME)) as last_purchase, 
    DATEDIFF(DAY, MIN(CAST(InvoiceDate AS DATETIME)), 
    MAX(CAST(InvoiceDate AS DATETIME))) as customer_lifetime_days,
    ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as customer_lifetime_value 
FROM MyDatabase.dbo.online_retail 
WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 AND CustomerID IS NOT NULL 
