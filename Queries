--QUERY 8 RFM Segmentation 
WITH rfm AS 
(   SELECT CustomerID, DATEDIFF(DAY, MAX(CAST(InvoiceDate AS DATETIME)), '2011-12-09') 
    as recency, COUNT(DISTINCT InvoiceNo) as frequency, 
    ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as monetary 
    FROM MyDatabase.dbo.online_retail 
    WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 AND CustomerID IS NOT NULL 
    GROUP BY CustomerID ) 
    SELECT CustomerID, recency, frequency, monetary, 
    CASE    WHEN recency <= 30 AND frequency >= 5 AND monetary >= 1000 
            THEN 'VIP' 
            WHEN recency <= 90 AND frequency >= 3 AND monetary >= 500 
            THEN 'Gold' 
            WHEN recency > 180 OR frequency = 1 
            THEN 'At-Risk' 
            ELSE 'Regular' 
            END as customer_segment 
            FROM rfm 
            ORDER BY monetary DESC;

--QUERY 9 Repeat Purchase Rate 
WITH customer_orders AS 
(   SELECT CustomerID, 
    COUNT(DISTINCT InvoiceNo) as num_orders 
    FROM MyDatabase.dbo.online_retail 
    WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 AND CustomerID IS NOT NULL 
    GROUP BY CustomerID ) 
  SELECT SUM(CASE WHEN num_orders >= 2 THEN 1 ELSE 0 END) as repeat_customers, 
         SUM(CASE WHEN num_orders = 1 THEN 1 ELSE 0 END) as one_time_customers, 
         COUNT(*) as total_customers, 
         ROUND(SUM(CASE WHEN num_orders >= 2 THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 2) as repeat_rate_pct 
         FROM customer_orders;

--QUERY 10 Customer Concentration (80/20 Rule) 
WITH customer_revenue AS ( SELECT CustomerID, 
ROUND(SUM(CAST(Quantity AS INT) * CAST(UnitPrice AS FLOAT)), 2) as customer_revenue 
FROM MyDatabase.dbo.online_retail 
WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 AND CustomerID IS NOT NULL 
GROUP BY CustomerID ), ranked AS ( SELECT CustomerID, customer_revenue, 
SUM(customer_revenue) OVER (ORDER BY customer_revenue DESC) as running_total, 
(SELECT SUM(customer_revenue) FROM customer_revenue) as total_revenue, 
CAST(100.0 * SUM(customer_revenue) 
OVER (ORDER BY customer_revenue DESC) / (SELECT SUM(customer_revenue) 
FROM customer_revenue) AS DECIMAL(5,2)) as cumulative_pct FROM customer_revenue ) 
SELECT TOP 1 COUNT(DISTINCT CustomerID) as top_customers_for_80pct, 
ROUND(AVG(customer_revenue), 2) as avg_customer_value 
FROM ranked 
WHERE cumulative_pct <= 80;

--QUERY 11 Inactive Customers (Churn Risk) 
WITH last_purchase AS 
( 
    SELECT CustomerID, MAX(CAST(InvoiceDate AS DATETIME)) as last_purchase_date 
    FROM MyDatabase.dbo.online_retail 
    WHERE CAST(Quantity AS INT) > 0 AND CAST(UnitPrice AS FLOAT) > 0 AND CustomerID IS NOT NULL 
    GROUP BY CustomerID ) 
    SELECT COUNT(*) as inactive_90days, 
    COUNT(CASE WHEN DATEDIFF(DAY, last_purchase_date, '2011-12-09') > 180 THEN 1 END) as inactive_180days, 
    COUNT(CASE WHEN DATEDIFF(DAY, last_purchase_date, '2011-12-09') > 365 THEN 1 END) as inactive_1year 
    FROM last_purchase WHERE DATEDIFF(DAY, last_purchase_date, '2011-12-09') > 90;

